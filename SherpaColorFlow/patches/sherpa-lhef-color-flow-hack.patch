 #include "ATOOLS/Org/My_MPI.H"
 
 #include <iomanip>
+#include <algorithm>
 #include <stdio.h>
 #include <cassert>
+#include <vector>
 
 using namespace SHERPA;
 using namespace ATOOLS;
 using namespace std;
 
+namespace {
+
+bool IsFinalQuarkWithoutFlow(Particle *const p)
+{
+  const long int kf((long int)p->Flav());
+  const long int akf(kf<0 ? -kf : kf);
+  return akf>=1 && akf<=6 && p->GetFlow(1)==0 && p->GetFlow(2)==0;
+}
+
+int NextLHEColourTag(Blob_List *const blobs)
+{
+  int tag(500);
+  for (Blob_List::iterator blit(blobs->begin());blit!=blobs->end();++blit) {
+    for (int i(0);i<(*blit)->NInP();++i) {
+      tag=std::max(tag,static_cast<int>((*blit)->InParticle(i)->GetFlow(1)));
+      tag=std::max(tag,static_cast<int>((*blit)->InParticle(i)->GetFlow(2)));
+    }
+    for (int i(0);i<(*blit)->NOutP();++i) {
+      tag=std::max(tag,static_cast<int>((*blit)->OutParticle(i)->GetFlow(1)));
+      tag=std::max(tag,static_cast<int>((*blit)->OutParticle(i)->GetFlow(2)));
+    }
+  }
+  return tag<501 ? 501 : tag+1;
+}
+
+void AssignMissingQQbarSinglet(Blob_List *const blobs)
+{
+  Particle *q(NULL), *qb(NULL);
+  long int qflav(0), qbflav(0);
+  size_t nq(0), nqb(0);
+
+  for (Blob_List::iterator blit(blobs->begin());blit!=blobs->end();++blit) {
+    for (int i(0);i<(*blit)->NOutP();++i) {
+      Particle *const p((*blit)->OutParticle(i));
+      if (!IsFinalQuarkWithoutFlow(p)) continue;
+      const long int kf((long int)p->Flav());
+      const long int akf(kf<0 ? -kf : kf);
+      if (kf>0) {
+        q=p;
+        qflav=akf;
+        ++nq;
+      }
+      else {
+        qb=p;
+        qbflav=akf;
+        ++nqb;
+      }
+    }
+  }
+
+  if (nq==0 && nqb==0) return;
+
+  if (nq!=1 || nqb!=1 || qflav!=qbflav) {
+    const std::string msg(std::string("LHEF_ASSIGN_MISSING_QQBAR_SINGLET "
+          "expected exactly one same-flavour zero-flow final q/qbar pair, "
+          "but found ")+ToString(nq)+" quark(s) and "+ToString(nqb)
+          +" antiquark(s).");
+    THROW(fatal_error,msg);
+  }
+
+  const int tag(NextLHEColourTag(blobs));
+  q->SetFlow(1,tag);
+  qb->SetFlow(2,tag);
+}
+
+}
